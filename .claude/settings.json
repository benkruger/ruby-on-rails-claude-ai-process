{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git push -u *)",
      "Bash(git tag *)",
      "Bash(git describe *)",
      "Bash(git reset HEAD)",
      "Bash(git pull origin *)",
      "Bash(git log *)",
      "Bash(git worktree *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(gh release create *)",
      "Bash(gh run list *)",
      "Bash(python3 hooks/check-phase.py *)",
      "Bash(python3 hooks/extract-release-notes.py *)",
      "Bash(git check-ignore *)",
      "Bash(git rm .flow-commit-*)",
      "Bash(rm .flow-commit-*)",
      "Bash(bin/ci)",
      "Bash(claude plugin marketplace update *)"
    ],
    "deny": [
      "Bash(git rebase *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
