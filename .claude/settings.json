{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git push -u *)",
      "Bash(git tag *)",
      "Bash(git describe *)",
      "Bash(git reset HEAD)",
      "Bash(git pull *)",
      "Bash(git log *)",
      "Bash(git worktree *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(gh release create *)",
      "Bash(gh run list *)",
      "Bash(python3 *)",
      "Bash(git check-ignore *)",
      "Bash(git rm *)",
      "Bash(chmod *)",
      "Bash(env *)",
      "Bash(open *)",
      "Bash(rm .flow-commit-*)",
      "Bash(rm -f *.claude/flow-states/*)",
      "Bash(bin/ci)"
    ],
    "deny": [
      "Bash(git rebase *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
