#!/usr/bin/env bash
# FLOW dispatcher — routes subcommands to the Rust binary.
#
# Usage: bin/flow <subcommand> [args...]
# Example: bin/flow start-init "Invoice Pdf Export"
#
# Dispatch: tries the Rust binary first. If it exits 127
# (unknown subcommand), returns an error. Auto-rebuilds when
# source is newer than the binary.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ $# -eq 0 ]; then
  echo '{"status":"error","message":"Usage: bin/flow <subcommand> [args...]"}'
  exit 1
fi

subcmd="$1"
shift

# Find Rust binary. Contributors hit target/release or target/debug
# first; end users who installed via the marketplace fall back to the
# committed prebuilt binary at bin/flow-rs-darwin-arm64.
RUST_BIN=""
if [ -x "$SCRIPT_DIR/../target/release/flow-rs" ]; then
  RUST_BIN="$SCRIPT_DIR/../target/release/flow-rs"
elif [ -x "$SCRIPT_DIR/../target/debug/flow-rs" ]; then
  RUST_BIN="$SCRIPT_DIR/../target/debug/flow-rs"
elif [ -x "$SCRIPT_DIR/../bin/flow-rs-darwin-arm64" ]; then
  RUST_BIN="$SCRIPT_DIR/../bin/flow-rs-darwin-arm64"
fi

# Auto-rebuild stale Rust binary
REPO_ROOT="$SCRIPT_DIR/.."
if [ -f "$REPO_ROOT/Cargo.toml" ] && [ -d "$REPO_ROOT/src" ]; then
  needs_build=false
  if [ -z "$RUST_BIN" ]; then
    needs_build=true
  elif find "$REPO_ROOT/src" "$REPO_ROOT/Cargo.toml" -newer "$RUST_BIN" -print -quit 2>/dev/null | grep -q .; then
    needs_build=true
  fi
  if [ "$needs_build" = true ]; then
    if cargo build --manifest-path "$REPO_ROOT/Cargo.toml" 2>/dev/null; then
      # Re-resolve after successful build
      RUST_BIN=""
      if [ -x "$REPO_ROOT/target/release/flow-rs" ]; then
        RUST_BIN="$REPO_ROOT/target/release/flow-rs"
      elif [ -x "$REPO_ROOT/target/debug/flow-rs" ]; then
        RUST_BIN="$REPO_ROOT/target/debug/flow-rs"
      fi
    fi
  fi
fi

if [ -n "$RUST_BIN" ]; then
  set +e
  "$RUST_BIN" "$subcmd" "$@"
  rc=$?
  set -e
  if [ $rc -ne 127 ]; then
    exit $rc
  fi
  # Exit 127 = unknown subcommand in Rust, fall through to error
fi

# No handler available — fail closed for hooks, error for everything else
if [ "$subcmd" = "hook" ]; then
  echo "BLOCKED: FLOW hook validator unavailable. The Rust binary is missing and cargo is not available to build it. Install cargo or run 'cargo build --release' in the plugin directory." >&2
  exit 2
fi
echo "{\"status\":\"error\",\"message\":\"Unknown subcommand: $subcmd\"}"
exit 1
